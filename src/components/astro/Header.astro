---
import { Moon, Sun } from 'lucide-react';
import { base } from '../../lib/paths';
---

<header class="sticky top-0 z-50 border-b border-line backdrop-blur-md" style="background: color-mix(in oklab, var(--bg) 88%, transparent)">
  <div class="mx-auto flex h-[60px] max-w-[1320px] items-center justify-between gap-3 px-5">
    <a href={base} class="flex items-baseline gap-0.5 text-ink no-underline">
      <span class="text-xl font-bold tracking-tight">Compress</span><span class="font-serif text-[22px] italic text-accent">Karo</span>
    </a>
    <button
      id="theme-toggle"
      type="button"
      class="group flex cursor-pointer items-center gap-2 rounded-full border border-line bg-surface px-3.5 py-[7px] text-[13px] font-medium text-ink transition-colors hover:border-accent"
      aria-label="Switch theme"
    >
      <span class="theme-icon-moon flex text-accent transition-transform duration-300 group-hover:-rotate-25">
        <Moon size={14} strokeWidth={2.2} aria-hidden="true" />
      </span>
      <span class="theme-icon-sun flex text-accent transition-transform duration-300 group-hover:rotate-45">
        <Sun size={14} strokeWidth={2.2} aria-hidden="true" />
      </span>
      <span id="theme-label"></span>
    </button>
  </div>
</header>

<style>
  /* Show the icon of the theme you'd switch TO (matches the label). */
  html[data-theme='dark'] .theme-icon-moon {
    display: none;
  }
  html:not([data-theme='dark']) .theme-icon-sun {
    display: none;
  }
</style>

<script>
  const root = document.documentElement;
  const label = document.getElementById('theme-label')!;

  const paint = () => {
    label.textContent = root.getAttribute('data-theme') === 'dark' ? 'Light' : 'Dark';
  };
  paint();

  document.getElementById('theme-toggle')!.addEventListener('click', () => {
    const dark = root.getAttribute('data-theme') !== 'dark';
    root.setAttribute('data-theme', dark ? 'dark' : 'light');
    try {
      localStorage.setItem('ck-theme', dark ? 'dark' : 'light');
    } catch {
      /* private mode */
    }
    paint();
  });
</script>
