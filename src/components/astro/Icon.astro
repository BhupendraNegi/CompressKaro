---
/** Inline stroke icon set ported from the design prototype (docs/Design-System.md §8). */
interface Props {
  name: string;
  size?: number;
}

const { name, size = 20 } = Astro.props;

const glyphs: Record<string, string> = {
  merge: '<rect x="4" y="4" width="11" height="13" rx="2"/><rect x="9" y="8" width="11" height="13" rx="2"/>',
  split: '<rect x="4" y="4" width="16" height="16" rx="2"/><line x1="12" y1="4" x2="12" y2="20" stroke-dasharray="3 3"/>',
  compress: '<rect x="4" y="4" width="16" height="16" rx="2"/><polyline points="9 12 12 15 15 12"/><line x1="12" y1="8" x2="12" y2="15"/>',
  rotate: '<rect x="7" y="7" width="10" height="10" rx="2"/><polyline points="17 2 21 5 17 8"/><line x1="21" y1="5" x2="12" y2="5"/>',
  crop: '<line x1="7" y1="2" x2="7" y2="17"/><line x1="2" y1="7" x2="17" y2="7"/><line x1="17" y1="7" x2="17" y2="22"/><line x1="7" y1="17" x2="22" y2="17"/>',
  pages: '<line x1="5" y1="6" x2="19" y2="6"/><line x1="5" y1="12" x2="19" y2="12"/><line x1="5" y1="18" x2="19" y2="18"/>',
  extract: '<rect x="5" y="3" width="14" height="18" rx="2"/><polyline points="9 12 12 15 15 12"/><line x1="12" y1="8" x2="12" y2="15"/>',
  del: '<rect x="5" y="3" width="14" height="18" rx="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/>',
  img: '<rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="2"/><polyline points="4 18 10 13 15 17 20 13"/>',
  doc: '<rect x="5" y="3" width="14" height="18" rx="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="15" y2="13"/>',
  text: '<line x1="5" y1="6" x2="19" y2="6"/><line x1="12" y1="6" x2="12" y2="19"/>',
  create: '<rect x="5" y="3" width="14" height="18" rx="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>',
  annotate: '<line x1="5" y1="19" x2="11" y2="19"/><line x1="15" y1="4" x2="20" y2="9"/><line x1="7" y1="12" x2="15" y2="4"/><line x1="12" y1="17" x2="20" y2="9"/>',
  watermark: '<rect x="4" y="4" width="16" height="16" rx="2"/><line x1="7" y1="17" x2="17" y2="7"/>',
  hash: '<line x1="9" y1="4" x2="8" y2="20"/><line x1="16" y1="4" x2="15" y2="20"/><line x1="5" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="19" y2="15"/>',
  hf: '<rect x="4" y="4" width="16" height="16" rx="2"/><line x1="4" y1="8" x2="20" y2="8"/><line x1="4" y1="16" x2="20" y2="16"/>',
  lock: '<rect x="6" y="10" width="12" height="10" rx="2"/><circle cx="12" cy="7" r="3.5"/>',
  unlock: '<rect x="6" y="10" width="12" height="10" rx="2"/><circle cx="16" cy="5" r="3"/>',
  sign: '<line x1="4" y1="19" x2="20" y2="19"/><polyline points="6 15 10 8 13 13 16 6"/>',
  resize: '<rect x="4" y="4" width="16" height="16" rx="2"/><polyline points="13 16 16 16 16 13"/><line x1="16" y1="16" x2="10" y2="10"/>',
  convert: '<polyline points="16 3 21 8 16 13"/><line x1="21" y1="8" x2="6" y2="8"/><polyline points="8 11 3 16 8 21"/><line x1="3" y1="16" x2="18" y2="16"/>',
  exif: '<circle cx="12" cy="12" r="8"/><line x1="6" y1="18" x2="18" y2="6"/>',
  flip: '<line x1="12" y1="3" x2="12" y2="21" stroke-dasharray="3 3"/><rect x="3" y="8" width="6" height="8" rx="1.5"/><rect x="15" y="8" width="6" height="8" rx="1.5"/>',
};
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={glyphs[name] ?? glyphs.doc}
/>
