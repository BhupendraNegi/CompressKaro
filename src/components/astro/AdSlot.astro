---
/**
 * Reserved, non-intrusive ad slot below the tool area (spec). A styled
 * placeholder for now — swap the inner div for an AdSense unit later.
 */
---

<aside class="mt-7" aria-label="Advertisement">
  <p class="mb-1.5 text-center text-[10px] tracking-[0.14em] text-mute uppercase">Advertisement</p>
  <div
    class="flex h-[90px] items-center justify-center rounded-[14px] border border-line"
    style="background: repeating-linear-gradient(45deg, var(--surface2), var(--surface2) 8px, var(--surface) 8px, var(--surface) 16px)"
  >
    <span class="font-mono text-xs text-mute">ad slot · 728×90 / responsive</span>
  </div>
</aside>
