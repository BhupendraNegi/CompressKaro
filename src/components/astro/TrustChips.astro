---
/**
 * Trust signals — large pills (home hero) or small rows (tool pages).
 * Lucide icons render statically (React renderer, zero client JS); the large
 * chips lift on hover and their icon pops.
 */
import { BadgeCheck, Cpu, UserX, Infinity as InfinityIcon } from 'lucide-react';

interface Props {
  variant?: 'large' | 'small';
}

const { variant = 'large' } = Astro.props;
const chips = [
  { label: '100% free', Icon: BadgeCheck },
  { label: 'Processed in your browser', Icon: Cpu },
  { label: 'No signup', Icon: UserX },
  { label: 'No file limits', Icon: InfinityIcon },
];
---

{
  variant === 'large' ? (
    <div class="mt-6 flex flex-wrap justify-center gap-2">
      {chips.map(({ label, Icon }) => (
        <span class="group inline-flex cursor-default items-center gap-2 rounded-full border border-line bg-surface px-3.5 py-[7px] text-[13px] font-medium text-ink transition-all duration-200 hover:-translate-y-0.5 hover:border-accent hover:bg-accent-soft hover:shadow-card">
          <span class="flex text-accent transition-transform duration-200 group-hover:scale-125 group-hover:-rotate-12">
            <Icon size={14} strokeWidth={2.2} aria-hidden="true" />
          </span>
          {label}
        </span>
      ))}
    </div>
  ) : (
    <div class="flex flex-wrap gap-3.5">
      {chips.map(({ label, Icon }) => (
        <span class="group inline-flex cursor-default items-center gap-1.5 text-[12.5px] text-mute transition-colors duration-200 hover:text-accent">
          <span class="flex text-accent transition-transform duration-200 group-hover:scale-125">
            <Icon size={12} strokeWidth={2.2} aria-hidden="true" />
          </span>
          {label}
        </span>
      ))}
    </div>
  )
}
