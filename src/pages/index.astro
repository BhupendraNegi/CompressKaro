---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="CompressKaro — Free PDF & Image tools"
  description="Free PDF & image tools that run 100% in your browser. Your files never leave your device."
>
  <main class="mx-auto max-w-[1120px] px-5 py-16 text-center">
    <h1 class="text-5xl font-semibold tracking-tight">
      Compress<span class="italic" style="color: var(--accent)">Karo</span>
    </h1>
    <p class="mt-4 text-lg" style="color: var(--muted)">
      Free PDF &amp; Image tools. 100% private — files never leave your device.
    </p>
    <p class="mt-2 text-sm" style="color: var(--muted)">Phase 0 scaffold — tools coming soon.</p>
  </main>
</BaseLayout>
