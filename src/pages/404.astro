---
import BaseLayout from '../layouts/BaseLayout.astro';
import { base } from '../lib/paths';
---

<BaseLayout title="Page not found — CompressKaro" description="That page doesn't exist. Browse our free, private PDF and image tools.">
  <main class="mx-auto max-w-[760px] px-5 py-24 text-center">
    <p class="m-0 font-serif text-[64px] italic text-accent">404</p>
    <h1 class="mt-2 mb-0 text-2xl font-semibold">Yeh page nahi mila.</h1>
    <p class="mt-3 text-[15px] text-mute">The page you're looking for doesn't exist — but the tools do.</p>
    <a href={base} class="mt-6 inline-block rounded-[14px] bg-accent px-7 py-3.5 font-semibold text-accent-ink no-underline shadow-card-lg">Browse all tools</a>
  </main>
</BaseLayout>
