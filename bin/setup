#!/usr/bin/env bash
# bin/setup — one-time setup for CompressKaro local development.
#
# Idempotent: safe to run repeatedly. Gets you from a fresh clone to a ready
# state — a dedicated Colima profile up, the dev image built, and the pnpm
# lockfile present. CompressKaro has no backing services and no host toolchain
# requirement: everything runs inside the container.
set -euo pipefail

cd "$(dirname "$0")/.."

# ── dedicated Colima instance ────────────────────────────────────────────────
# Our own "compresskaro" profile so we never touch other Colima profiles.
# DOCKER_HOST pins docker/compose to this instance without changing your
# active context.
COLIMA_PROFILE="compresskaro"
export DOCKER_HOST="unix://${HOME}/.colima/${COLIMA_PROFILE}/docker.sock"

# ── pretty output ────────────────────────────────────────────────────────────
bold() { printf "\033[1m%s\033[0m\n" "$1"; }
info() { printf "\033[34m▸\033[0m %s\n" "$1"; }
ok()   { printf "\033[32m✓\033[0m %s\n" "$1"; }
die()  { printf "\033[31m✗ %s\033[0m\n" "$1" >&2; exit 1; }

bold "CompressKaro setup"

# ── prerequisites ────────────────────────────────────────────────────────────
command -v docker >/dev/null 2>&1 || die "Docker not found. Install the Docker CLI (e.g. 'brew install docker')."
command -v colima >/dev/null 2>&1 || die "Colima not found. Install it with 'brew install colima'."
[ -f package.json ] || die "No package.json yet — the app scaffold (Phase 0) hasn't landed. See docs/Progress.md."
ok "Prerequisites present (docker, colima)"

# ── Colima (Docker daemon) ───────────────────────────────────────────────────
if colima status "$COLIMA_PROFILE" >/dev/null 2>&1; then
  ok "Colima profile '$COLIMA_PROFILE' already running"
else
  info "Starting Colima profile '$COLIMA_PROFILE'…"
  colima start "$COLIMA_PROFILE" --cpu 2 --memory 4 --disk 20
  ok "Colima profile '$COLIMA_PROFILE' started"
fi

# ── dev image ────────────────────────────────────────────────────────────────
info "Building the dev image (installs pnpm deps)…"
docker compose build
ok "Dev image built"

# ── lockfile ─────────────────────────────────────────────────────────────────
# The image build generates pnpm-lock.yaml; the runtime bind-mount shadows it,
# so extract it to the repo for CI's --frozen-lockfile if it isn't there yet.
# (After that, keep it fresh with:
#   docker compose run --rm web pnpm install --lockfile-only)
if [ -f pnpm-lock.yaml ]; then
  ok "pnpm-lock.yaml present"
else
  info "Extracting pnpm-lock.yaml from the image…"
  docker run --rm --entrypoint sh compresskaro-web:latest -c "cat pnpm-lock.yaml" > pnpm-lock.yaml
  ok "pnpm-lock.yaml written"
fi

echo
bold "Setup complete 🎉"
echo "Next:  bin/dev         # start the dev server (tears the container down on exit)"
echo "       bin/test        # run the vitest suite"
echo "       bin/lint        # eslint + typecheck"
