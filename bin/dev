#!/usr/bin/env bash
# bin/dev — start the CompressKaro dev server inside the container.
#
# Ensures the Colima profile is up, then runs `astro dev` in Docker with the
# source bind-mounted for hot reload. Ctrl-C / exit tears the container down.
#
# Port: defaults to 4321 (Astro's default), override with `PORT=5000 bin/dev`
# or `bin/dev 5000`. If the chosen port is busy, the next free port is used.
set -euo pipefail

cd "$(dirname "$0")/.."

# Dedicated Colima instance — see bin/setup for the rationale.
COLIMA_PROFILE="compresskaro"
export DOCKER_HOST="unix://${HOME}/.colima/${COLIMA_PROFILE}/docker.sock"

info() { printf "\033[34m▸\033[0m %s\n" "$1"; }
ok()   { printf "\033[32m✓\033[0m %s\n" "$1"; }
warn() { printf "\033[33m!\033[0m %s\n" "$1"; }
die()  { printf "\033[31m✗ %s\033[0m\n" "$1" >&2; exit 1; }

# ── tear the container down on exit ──────────────────────────────────────────
CLEANED=""
cleanup() {
  [ -n "$CLEANED" ] && return; CLEANED=1
  echo
  info "Stopping container…"
  docker compose down >/dev/null 2>&1 || true
  ok "Stopped. Bye 👋"
}
trap cleanup EXIT INT TERM

# ── prerequisites / daemon ───────────────────────────────────────────────────
command -v colima >/dev/null 2>&1 || die "Colima not found. Run bin/setup first."
if ! colima status "$COLIMA_PROFILE" >/dev/null 2>&1; then
  info "Starting Colima profile '$COLIMA_PROFILE'…"
  colima start "$COLIMA_PROFILE" --cpu 2 --memory 4 --disk 20
fi

# ── pick a free host port ────────────────────────────────────────────────────
PORT="${1:-${PORT:-4321}}"
port_busy() { lsof -nP -iTCP:"$1" -sTCP:LISTEN >/dev/null 2>&1; }
if port_busy "$PORT"; then
  warn "Port $PORT is in use; searching for a free one…"
  for p in $(seq "$PORT" $((PORT + 20))); do
    port_busy "$p" || { PORT="$p"; break; }
  done
fi
export PORT

echo
ok "Starting Astro on http://localhost:${PORT}"
info "Press Ctrl-C to stop (the container will be torn down)."
echo

# Foreground compose; Ctrl-C stops it and fires the cleanup trap.
docker compose up
